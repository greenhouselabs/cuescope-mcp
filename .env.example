# CueScope MCP - environment variables
#
# MCP clients usually pass these through the "env" block of the server entry
# in their MCP configuration (e.g. claude_desktop_config.json) rather than a
# .env file. This file documents every supported variable with its default.
#
# Boolean variables use canonical true/false values.
# Leave a variable unset to use its default.

# --- vMix connection ---------------------------------------------------------

# vMix hostname or IP address. Use the vMix machine's IP when the MCP server
# runs on a different (trusted) machine.
VMIX_HOST=localhost

# vMix Web Controller HTTP API port (Settings > Web Controller in vMix).
VMIX_HTTP_PORT=8088

# vMix TCP API port, used for real-time tally subscriptions. Optional; the
# server runs HTTP-only if TCP is unavailable.
VMIX_TCP_PORT=8099

# --- TCP connection behavior -------------------------------------------------

# Enable TCP tally subscriptions (true/false). Set to false to silence
# reconnect attempts when the vMix TCP API is not reachable.
TCP_ENABLED=true

# Delay between TCP reconnect attempts, in milliseconds (100-60000).
TCP_RECONNECT_DELAY=5000

# Maximum number of TCP reconnect attempts (0-100).
TCP_MAX_RECONNECTS=10

# TCP connection timeout, in milliseconds (1000-30000).
TCP_CONNECT_TIMEOUT=10000

# --- Safety modes ------------------------------------------------------------

# Review Mode is the default: read-first, no vMix mutation. Set to true only
# when you intentionally want live-control tools exposed to the assistant.
VMIX_CONTROL_MODE=false

# Second opt-in for the highest-impact tools (scripts, batch commands,
# recording, streaming, presets, output routing, destructive input actions,
# show-building, replay recording). Requires VMIX_CONTROL_MODE=true as well.
# Rehearse on a non-production preset before using during a live show.
VMIX_HIGH_IMPACT=false

# --- State caching -----------------------------------------------------------

# Parsed vMix state cache TTL, in milliseconds (0-10000).
STATE_CACHE_TTL=100

# --- Skills system -----------------------------------------------------------

# Override the bundled skill-guidance directory. Optional; defaults to the
# skills bundled with the package.
#SKILLS_PATH=

# Directory of your own skills (each at <dir>/<name>/SKILL.md), merged with
# the bundled ones in the vmix://skills resource. Optional.
#VMIX_USER_SKILLS_PATH=

# --- Preset files ------------------------------------------------------------

# Optional directory that confines preset-file reads. When set, the
# preset-file tools (vmix_read_preset_file, vmix_explain_preset_scripts,
# vmix_audit_preset_file, vmix_preflight cross-reference) only read .vmix
# files inside this directory.
#VMIX_PRESET_ROOT=

# --- Logging -----------------------------------------------------------------

# One of: debug, info, warn, error. Logs are written to stderr.
LOG_LEVEL=info
