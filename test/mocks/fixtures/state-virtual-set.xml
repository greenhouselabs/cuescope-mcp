      <layer index="3" input="4" key="{virtual-title}" title="Virtual Set Lower Third" zoom="1" panX="0" panY="-0.72"/>
    </input>
    <input key="{virtual-title}" number="4" type="GT" title="Virtual Set Lower Third" state="" position="0" duration="0" muted="False" loop="False" audiobusses="">
      <text name="Name.Text">Studio Host</text>
      <text name="Topic.Text">Morning Update</text>
    </input>
  </inputs>
  <overlays>
    <overlay number="1">4</overlay>
    <overlay number="2"></overlay>
    <overlay number="3"></overlay>
    <overlay number="4"></overlay>
